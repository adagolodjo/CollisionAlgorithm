#!/bin/bash
# Pre-commit hook for CollisionAlgorithm
# Automatically format C++ files with clang-format

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit hooks...${NC}"

# Check if clang-format is installed
if ! command -v clang-format &> /dev/null; then
    echo -e "${RED}Error: clang-format not found${NC}"
    echo "Please install clang-format:"
    echo "  macOS: brew install clang-format"
    echo "  Ubuntu: sudo apt-get install clang-format"
    exit 1
fi

# Get list of staged C++ files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h|inl)$')

if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}No C++ files to format${NC}"
    exit 0
fi

echo -e "${YELLOW}Formatting staged C++ files...${NC}"

# Format each file
FORMATTED_FILES=""
for FILE in $STAGED_FILES; do
    if [ -f "$FILE" ]; then
        echo "  Formatting $FILE"
        clang-format -i -style=file "$FILE"
        git add "$FILE"
        FORMATTED_FILES="$FORMATTED_FILES $FILE"
    fi
done

if [ -n "$FORMATTED_FILES" ]; then
    echo -e "${GREEN}✓ Formatted files:${NC}$FORMATTED_FILES"
fi

# Optional: Run clang-tidy on staged files (can be slow)
RUN_TIDY=${RUN_CLANG_TIDY:-0}

if [ "$RUN_TIDY" = "1" ]; then
    echo -e "${YELLOW}Running clang-tidy...${NC}"
    
    if [ ! -f "build/compile_commands.json" ]; then
        echo -e "${YELLOW}Warning: compile_commands.json not found${NC}"
        echo "Skipping clang-tidy. To enable:"
        echo "  cmake -B build -DCMAKE_EXPORT_COMPILE_COMMANDS=ON"
    else
        TIDY_FAILED=0
        for FILE in $STAGED_FILES; do
            if [ -f "$FILE" ] && [[ "$FILE" =~ \.cpp$ ]]; then
                echo "  Checking $FILE"
                if ! clang-tidy "$FILE" -p build --quiet; then
                    TIDY_FAILED=1
                fi
            fi
        done
        
        if [ $TIDY_FAILED -eq 1 ]; then
            echo -e "${RED}✗ clang-tidy found issues${NC}"
            echo "Fix the issues or commit with --no-verify to skip"
            exit 1
        fi
    fi
fi

echo -e "${GREEN}✓ Pre-commit checks passed${NC}"
exit 0
